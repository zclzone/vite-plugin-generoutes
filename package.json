{
  "name": "vue-auto-pages",
  "type": "module",
  "version": "0.1.0",
  "packageManager": "pnpm@10.28.2",
  "description": "Convention-based file routing for Vue and Vite with layouts, typed metadata, and HMR.",
  "author": "Ronnie Zhang <zclzone@outlook.com>",
  "license": "MIT",
  "homepage": "https://github.com/zclzone/vue-auto-pages",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/zclzone/vue-auto-pages.git"
  },
  "bugs": "https://github.com/zclzone/vue-auto-pages/issues",
  "keywords": [
    "vue",
    "vite",
    "vue-router",
    "file-based-routing",
    "pages",
    "layouts"
  ],
  "sideEffects": false,
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./client": {
      "types": "./client.d.ts",
      "default": "./client.d.ts"
    }
  },
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "typesVersions": {
    "*": {
      "client": [
        "./client.d.ts"
      ],
      "*": [
        "./dist/*",
        "./dist/index.d.ts"
      ]
    }
  },
  "files": [
    "client.d.ts",
    "dist"
  ],
  "engines": {
    "node": "^20.19.0 || >=22.12.0"
  },
  "scripts": {
    "start": "tsup --watch",
    "build": "tsup",
    "verify": "pnpm build && node scripts/verify-errors.mjs",
    "lint": "eslint .",
    "prepublishOnly": "nr build",
    "release": "bumpp && npm publish",
    "test": "vitest",
    "prepare": "simple-git-hooks",
    "up:deps": "taze major -I"
  },
  "peerDependencies": {
    "vite": ">=6.4.1",
    "vue-router": ">=4.0.0"
  },
  "dependencies": {
    "@antfu/utils": "^9.3.0",
    "@babel/parser": "^7.29.0",
    "@vue/compiler-sfc": "^3.5.27",
    "glob": "^13.0.0"
  },
  "devDependencies": {
    "@antfu/eslint-config": "^7.2.0",
    "@antfu/ni": "^28.2.0",
    "@types/node": "^25.2.0",
    "bumpp": "^10.4.0",
    "eslint": "^9.39.2",
    "lint-staged": "^16.2.7",
    "pnpm": "^10.28.2",
    "simple-git-hooks": "^2.13.1",
    "taze": "^19.9.2",
    "tsup": "^8.5.1",
    "typescript": "^5.9.3",
    "vitest": "^4.0.18",
    "vue-router": "^5.0.1"
  },
  "simple-git-hooks": {
    "pre-commit": "pnpm lint-staged"
  },
  "lint-staged": {
    "*": "eslint --fix"
  }
}
